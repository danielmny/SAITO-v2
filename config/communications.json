{
  "default_channel": "email",
  "channels": {
    "email": {
      "enabled": true,
      "provider": "gmail",
      "sender_identity": "",
      "reply_mode": "threaded",
      "polling_strategy": "gmail_inbox",
      "digest_recipients": [],
      "escalation_recipients": []
    },
    "slack": {
      "enabled": false,
      "provider": "slack",
      "workspace": "",
      "default_channel": "",
      "thread_replies": true
    }
  },
  "founder_reply_auth": {
    "required": true,
    "secret_env_var": "SAITO_FOUNDER_REPLY_SECRET",
    "reply_ttl_hours": 24
  },
  "message_types": {
    "digest": {
      "requires_reply": false
    },
    "escalation": {
      "requires_reply": true,
      "reply_sla_hours": 24
    },
    "reply_needed": {
      "requires_reply": true,
      "reply_sla_hours": 12
    }
  }
}
