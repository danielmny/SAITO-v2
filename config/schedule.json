{
  "system_version": "2.1",
  "timezone": "Europe/Madrid",
  "dispatcher": {
    "scheduler_of_record": "github_actions",
    "heartbeat_minutes": 15,
    "digest_hour_local": 18,
    "digest_minute_local": 0,
    "overdue_sweep_hours": 6
  },
  "agents": {
    "MERIDIAN-ORCHESTRATOR": {
      "function": "Orchestrator",
      "enabled": true,
      "phase": 1,
      "priority": 100,
      "trigger_mode": ["heartbeat", "event", "manual"],
      "heartbeat_minutes": 15,
      "cooldown_minutes": 15,
      "max_runs_per_day": 48,
      "run_if_changed": true,
      "depends_on": [],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/escalations/",
        "outputs/MERIDIAN-ORCHESTRATOR/"
      ],
      "quiet_hours_policy": {
        "mode": "digest_only",
        "start_hour_local": 1,
        "end_hour_local": 6
      }
    },
    "ATLAS-RESEARCH": {
      "function": "Market Research",
      "enabled": true,
      "phase": 1,
      "priority": 70,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 60,
      "cooldown_minutes": 180,
      "max_runs_per_day": 6,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/CURRENT-SALES/",
        "outputs/ATLAS-RESEARCH/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "CANVAS-PRODUCT": {
      "function": "Product",
      "enabled": true,
      "phase": 2,
      "priority": 60,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 120,
      "cooldown_minutes": 180,
      "max_runs_per_day": 4,
      "run_if_changed": true,
      "depends_on": ["ATLAS-RESEARCH", "CURRENT-SALES", "FORGE-ENGINEERING"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/CANVAS-PRODUCT/",
        "outputs/FORGE-ENGINEERING/",
        "outputs/CURRENT-SALES/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "FORGE-ENGINEERING": {
      "function": "Engineering",
      "enabled": true,
      "phase": 1,
      "priority": 80,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 30,
      "cooldown_minutes": 60,
      "max_runs_per_day": 12,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/FORGE-ENGINEERING/",
        "outputs/CANVAS-PRODUCT/"
      ],
      "quiet_hours_policy": {
        "mode": "allow_critical_only",
        "start_hour_local": 1,
        "end_hour_local": 6
      }
    },
    "MARKETING-BRAND": {
      "function": "Brand & Demand Gen",
      "enabled": true,
      "phase": 2,
      "priority": 50,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 120,
      "cooldown_minutes": 240,
      "max_runs_per_day": 4,
      "run_if_changed": true,
      "depends_on": ["ATLAS-RESEARCH", "CURRENT-SALES", "HERALD-COMMS"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/MARKETING-BRAND/",
        "outputs/ATLAS-RESEARCH/",
        "outputs/HERALD-COMMS/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "CURRENT-SALES": {
      "function": "Sales",
      "enabled": true,
      "phase": 1,
      "priority": 85,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 30,
      "cooldown_minutes": 60,
      "max_runs_per_day": 16,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/CURRENT-SALES/",
        "outputs/ATLAS-RESEARCH/",
        "outputs/HERALD-COMMS/"
      ],
      "quiet_hours_policy": {
        "mode": "allow_critical_only",
        "start_hour_local": 1,
        "end_hour_local": 6
      }
    },
    "LEDGER-FINANCE": {
      "function": "Finance & Fundraising",
      "enabled": true,
      "phase": 1,
      "priority": 65,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 120,
      "cooldown_minutes": 240,
      "max_runs_per_day": 4,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR", "HERALD-COMMS"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/LEDGER-FINANCE/",
        "outputs/HERALD-COMMS/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "NEXUS-TALENT": {
      "function": "Talent & Hiring",
      "enabled": true,
      "phase": 2,
      "priority": 40,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 60,
      "cooldown_minutes": 240,
      "max_runs_per_day": 2,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/NEXUS-TALENT/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "COUNSEL-LEGAL": {
      "function": "Legal",
      "enabled": true,
      "phase": 2,
      "priority": 40,
      "trigger_mode": ["manual", "event"],
      "heartbeat_minutes": 0,
      "cooldown_minutes": 240,
      "max_runs_per_day": 2,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/COUNSEL-LEGAL/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "VECTOR-ANALYTICS": {
      "function": "Analytics & Growth",
      "enabled": true,
      "phase": 2,
      "priority": 55,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 120,
      "cooldown_minutes": 180,
      "max_runs_per_day": 4,
      "run_if_changed": true,
      "depends_on": ["MARKETING-BRAND", "CURRENT-SALES"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/VECTOR-ANALYTICS/",
        "outputs/CURRENT-SALES/",
        "outputs/MARKETING-BRAND/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    },
    "HERALD-COMMS": {
      "function": "Investor Relations & PR",
      "enabled": true,
      "phase": 1,
      "priority": 75,
      "trigger_mode": ["event"],
      "heartbeat_minutes": 60,
      "cooldown_minutes": 180,
      "max_runs_per_day": 6,
      "run_if_changed": true,
      "depends_on": ["MERIDIAN-ORCHESTRATOR"],
      "context_inputs": [
        "config/company-brief.md",
        "outputs/state.json",
        "outputs/handoffs/",
        "outputs/HERALD-COMMS/",
        "outputs/LEDGER-FINANCE/"
      ],
      "quiet_hours_policy": {
        "mode": "suppress_noncritical",
        "start_hour_local": 0,
        "end_hour_local": 7
      }
    }
  }
}
